# Public application base URL used for magic-link redirects.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Supabase project values for local development and deployment.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_PROJECT_REF=

# Playwright uses these fixture accounts for dashboard auth tests.
E2E_ADMIN_EMAIL=admin-e2e@example.com
E2E_ADMIN_PASSWORD=admin-e2e-password
E2E_REGULAR_EMAIL=regular-e2e@example.com
E2E_REGULAR_PASSWORD=regular-e2e-password

# Optional override when running e2e against a deployed environment.
PLAYWRIGHT_BASE_URL=http://127.0.0.1:3000
